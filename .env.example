# ── MySQL Database ────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=photo_manager

# ── Photo Directories ─────────────────────────────────────────
# On WSL (Windows):  WATCH_DIR=/mnt/c/photo
# On native Linux:   WATCH_DIR=/home/youruser/photo
WATCH_DIR=/mnt/c/photo
IMAGES_ROOT=/mnt/c/photo/Images
VIDEOS_ROOT=/mnt/c/photo/Videos

# ── Gallery Web Server ────────────────────────────────────────
GALLERY_PORT=5050
# Generate a random key: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-secret-key

# ── Optional ──────────────────────────────────────────────────
THUMB_DIR=/tmp/gi_thumbs
